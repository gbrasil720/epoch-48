{
	"name": "epoch-48",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"dotenv": "^17.4.2",
			"zod": "^4.4.3",
			"typescript": "^6",
			"@types/bun": "^1.3.14",
			"hono": "^4.12.27",
			"@trpc/server": "^11.18.0",
			"lucide-react": "^1.23.0",
			"next-themes": "^0.4.6",
			"react": "^19.2.7",
			"react-dom": "^19.2.7",
			"sonner": "^2.0.7",
			"@trpc/client": "^11.18.0",
			"@tailwindcss/postcss": "^4.3.2",
			"@types/react": "^19.2.17",
			"@types/react-dom": "^19.2.3",
			"tailwindcss": "^4.3.2"
		}
	},
	"type": "module",
	"scripts": {
		"dev": "turbo run dev",
		"build": "turbo run build",
		"check-types": "turbo run check-types",
		"dev:web": "turbo run dev -F web",
		"dev:server": "turbo run dev -F server",
		"db:push": "turbo run db:push -F @epoch-48/db",
		"db:studio": "turbo run db:studio -F @epoch-48/db",
		"db:generate": "turbo run db:generate -F @epoch-48/db",
		"db:migrate": "turbo run db:migrate -F @epoch-48/db",
		"check": "biome check --write ."
	},
	"dependencies": {
		"@epoch-48/env": "workspace:*",
		"csv-parse": "^7.0.1",
		"dotenv": "catalog:",
		"framer-motion": "^12.42.2",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.2",
		"@epoch-48/config": "workspace:*",
		"@types/bun": "catalog:",
		"turbo": "^2.10.2",
		"typescript": "catalog:"
	},
	"packageManager": "bun@1.3.14"
}
